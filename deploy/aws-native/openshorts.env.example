# Copy to /etc/openshorts/openshorts.env
# Owner: root:openshorts
# Mode: 0640

PYTHONUNBUFFERED=1
HOME=/var/lib/openshorts

UPLOAD_DIR=/var/lib/openshorts/uploads
OUTPUT_DIR=/var/lib/openshorts/output
MAX_CONCURRENT_JOBS=1
DISABLE_YOUTUBE_URL=false

# Optional server-side fallback for an OpenAI-compatible endpoint.
# The dashboard can also save the endpoint, API key, and selected model.
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://router.example.com/v1
AI_API_KEY=replace_with_endpoint_api_key
AI_MODEL=google/gemini-2.5-flash
AI_TEMPERATURE=0.2
AI_TIMEOUT_SECONDS=180
AI_MAX_TOKENS=4096

# AWS uses the EC2 instance profile. Do not add static AWS keys here.
AWS_REGION=ap-southeast-3
AWS_S3_BUCKET=replace-private-bucket
AWS_S3_PUBLIC_BUCKET=replace-public-gallery-bucket

REMOTION_BUNDLE_PATH=/opt/openshorts/remotion
PORT=3100
