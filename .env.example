# OpenShorts native AWS runtime
PYTHONUNBUFFERED=1
HOME=/var/lib/openshorts

# Writable runtime data
UPLOAD_DIR=/var/lib/openshorts/uploads
OUTPUT_DIR=/var/lib/openshorts/output
MAX_CONCURRENT_JOBS=1

# OpenAI-compatible custom endpoint fallback.
# The dashboard can also save these values per browser session.
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://router.example.com/v1
AI_API_KEY=replace_with_endpoint_api_key
AI_MODEL=google/gemini-2.5-flash
AI_TEMPERATURE=0.2
AI_TIMEOUT_SECONDS=180
AI_MAX_TOKENS=4096

# AWS S3 (optional). On EC2, prefer an IAM instance role.
# Do not store long-lived AWS access keys on the VPS.
AWS_REGION=ap-southeast-3
AWS_S3_BUCKET=your-private-bucket-name
AWS_S3_PUBLIC_BUCKET=your-public-gallery-bucket-name

# Local-only fallback credentials, normally left unset on EC2:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# YouTube cookies (optional, Netscape format)
# YOUTUBE_COOKIES=...

# Remotion renderer
REMOTION_BUNDLE_PATH=/opt/openshorts/remotion
PORT=3100
